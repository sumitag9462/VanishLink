## Backend API
PORT=5050
MONGO_URI=mongodb://127.0.0.1:27017/vanish_link
REDIS_URL=redis://127.0.0.1:6379

## Security
JWT_SECRET=your_jwt_secret_here
HASH_SALT_SECRET=your_hash_salt_here
ADMIN_REGISTRATION_CODE=super_secret_invite_code

## OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5050/api/auth/google/callback

## Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@vanish.link

## AI Summaries (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

## Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

## Frontend (Vite)
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API base used by axios in src/services/api.js
VITE_API_URL=http://localhost:5050/api

# App URL used when building short links / QR codes
VITE_APP_URL=http://localhost:5173
